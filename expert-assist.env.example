# Expert Assist — environment variables (reference)
# Copy values into .env.local (do not commit secrets).

# Twilio SMS — REST uses API Key (recommended)
TWILIO_ACCOUNT_SID=
TWILIO_API_KEY_SID=
TWILIO_API_KEY_SECRET=

# Webhook signature validation uses your **primary Account Auth Token** from Twilio Console
# (Twilio does not sign webhooks with the API key secret). Prefer explicit name:
TWILIO_WEBHOOK_AUTH_TOKEN=
# Legacy REST (Account SID + Auth Token only — prefer API keys above)
# TWILIO_AUTH_TOKEN=

TWILIO_MESSAGING_SERVICE_SID=
# If no messaging service, set a From number instead:
# TWILIO_FROM_NUMBER=+1...

# Public base URL Twilio uses for webhooks (must match Messaging config)
TWILIO_WEBHOOK_BASE_URL=https://your-domain.com

# Optional copy overrides
# EXPERT_ASSIST_COPY_WELCOME=
# EXPERT_ASSIST_HELP_TEXT=

# Stripe (card on file + charges)
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=

# Vercel cron shared secret (?token=)
CRON_CONSULTS_TOKEN=

# Web intake form (POST /api/expert-assist/intake) — Bearer auth + optional CORS.
# Generate a long random string; same value is embedded in the static intake app config.
EXPERT_ASSIST_INTAKE_SECRET=
# Comma-separated origins allowed to call the intake API from a browser (e.g. https://your-intake.netlify.app).
# Leave unset for same-origin only (no CORS headers).
EXPERT_ASSIST_INTAKE_ALLOWED_ORIGINS=

# Slack (new cases, approvals, and idle-queue nudges from cron — no expert SMS)
# EXPERT_ASSIST_SLACK_WEBHOOK_URL=
# Resend (receipts / failures) — reuse existing CRM RESEND_API_KEY
# RESEND_API_KEY=
# RESEND_FROM=
